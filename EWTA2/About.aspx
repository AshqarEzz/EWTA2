<%@ Page Title="About" Language="C#" MasterPageFile="~/Site.Master"
    AutoEventWireup="true" CodeBehind="About.aspx.cs"
    Inherits="EWTA2.About" %>

<asp:Content ID="BodyContent"
    ContentPlaceHolderID="MainContent"
    runat="server">

    <div class="container mt-4">

        <h1 class="fw-bold mb-4">About EWTA </h1>

        <p style="font-size:18px; text-align:justify;">

            Employee Wages Tracking Application (EWTA) is a web-based ASP.NET
            application developed for managing employee and wage information
            inside an organization.

            The system allows users to store, update, manage, and report employee
            records and wage details efficiently using a SQL Server database.

        </p>

        <br />

        <h3 class="fw-bold">Main Features</h3>

        <ul style="font-size:18px;">

            <li>Employee Data Entry Form</li>

            <li>Employee Data Entry Wizard Form</li>

            <li>Wage Data Entry and Update</li>

            <li>Department Data Management</li>

            <li>Employee Communication Report</li>

            <li>Employees By Department Report</li>

            <li>Wages By Employee Report</li>

            <li>Employee Wage Graph Report</li>

            <li>Employee Wage Graph By Year</li>

            <li>Login and Session Management</li>

        </ul>

        <br />

        <h3 class="fw-bold">Technologies Used</h3>

        <ul style="font-size:18px;">

            <li>ASP.NET Web Forms</li>

            <li>C# Programming Language</li>

            <li>SQL Server Database</li>

            <li>Bootstrap for User Interface Design</li>

            <li>Visual Studio IDE</li>

        </ul>

        <br />

        <h3 class="fw-bold">Project Purpose</h3>

        <p style="font-size:18px; text-align:justify;">

            The purpose of this project is to provide a simple and effective
            employee wage management system where organizations can keep track
            of employees, departments, salaries, commissions, and reports
            through a user-friendly web interface.

        </p>

    </div>

</asp:Content>
